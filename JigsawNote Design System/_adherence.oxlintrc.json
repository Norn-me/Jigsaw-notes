{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/data-display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icons/**",
              "components/media/**",
              "components/navigation/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Onest))/i]",
        "message": "Font not provided by the design system. Available: Inter, Onest."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItemDef'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|title|subtitle|content|startContent|isDisabled|key|ref|className|style|children)$/]",
        "message": "<AccordionItemDef> doesn't accept that prop. Declared props: key, title, subtitle, content, startContent, isDisabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|children|color|variant|icon|isClosable|onClose|className|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: title, description, children, color, variant, icon, isClosable, onClose, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:default|primary|secondary|success|warning|danger)$/]",
        "message": "<Alert> color must be one of 'default' | 'primary' | 'secondary' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:flat|solid|bordered|faded)$/]",
        "message": "<Alert> variant must be one of 'flat' | 'solid' | 'bordered' | 'faded'."
      },
